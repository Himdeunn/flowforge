datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  users     User[]
  workflows WorkflowDefinition[]
  runs      WorkflowRun[]

  @@map("tenants")
}

enum Role {
  admin
  editor
  viewer
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String   @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdWorkflows WorkflowDefinition[] @relation("CreatedByUser")
  createdVersions  WorkflowVersion[]    @relation("CreatedVersionByUser")

  @@unique([tenantId, email])
  @@map("users")
}

model WorkflowDefinition {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  name             String   @db.VarChar(255)
  description      String?  @db.Text
  currentVersionId String?  @unique @map("current_version_id") @db.Uuid
  webhookToken     String?  @unique @map("webhook_token") @db.VarChar(64)
  cronExpression   String?  @map("cron_expression") @db.VarChar(100)
  isActive         Boolean  @default(true) @map("is_active")
  createdBy        String   @map("created_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator        User             @relation("CreatedByUser", fields: [createdBy], references: [id])
  currentVersion WorkflowVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions       WorkflowVersion[] @relation("DefinitionVersions")
  runs           WorkflowRun[]

  @@map("workflow_definitions")
}

model WorkflowVersion {
  id            String   @id @default(uuid()) @db.Uuid
  workflowId    String   @map("workflow_id") @db.Uuid
  versionNumber Int      @map("version_number")
  definitionJson Json     @map("definition_json") @db.JsonB
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  workflow   WorkflowDefinition   @relation("DefinitionVersions", fields: [workflowId], references: [id], onDelete: Cascade)
  creator    User                 @relation("CreatedVersionByUser", fields: [createdBy], references: [id])
  runs       WorkflowRun[]
  currentFor WorkflowDefinition? @relation("CurrentVersion")

  @@unique([workflowId, versionNumber])
  @@map("workflow_versions")
}

enum RunStatus {
  queued
  running
  completed
  failed
  timed_out
}

enum TriggerType {
  manual
  cron
  webhook
}

model WorkflowRun {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  workflowId  String      @map("workflow_id") @db.Uuid
  versionId   String      @map("version_id") @db.Uuid
  triggerType TriggerType @map("trigger_type")
  status      RunStatus
  startedAt   DateTime?   @map("started_at") @db.Timestamptz
  completedAt DateTime?   @map("completed_at") @db.Timestamptz
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version  WorkflowVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  stepRuns StepRun[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("workflow_runs")
}

enum StepStatus {
  pending
  running
  success
  failed
  skipped
  timed_out
}

model StepRun {
  id          String     @id @default(uuid()) @db.Uuid
  runId       String     @map("run_id") @db.Uuid
  stepKey     String     @map("step_key") @db.VarChar(100)
  status      StepStatus
  attempt     Int        @default(0)
  startedAt   DateTime?  @map("started_at") @db.Timestamptz
  completedAt DateTime?  @map("completed_at") @db.Timestamptz

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, stepKey])
  @@map("step_runs")
}
