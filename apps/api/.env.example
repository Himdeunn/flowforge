# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Connection URL for Prisma
DATABASE_URL=postgresql://flowforge:flowforge@localhost:5432/flowforge

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Append-only execution log store
MONGODB_URI=mongodb://localhost:27017/flowforge_logs

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used for BullMQ job queue and rate limiting
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate strong random secrets for production!
# Example: openssl rand -hex 64
JWT_ACCESS_SECRET=changeme-access-secret-min-32-chars
JWT_REFRESH_SECRET=changeme-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Required for AI workflow builder (Task 4.1)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Optional comma-separated list of Gemini API keys for automatic key rotation
GEMINI_API_KEYS=key1,key2,key3

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Worker ───────────────────────────────────────────────────────────────────
# Set to 'true' if this instance should NOT run BullMQ worker
# (use separate 'worker' container in docker-compose)
DISABLE_WORKER=false

# ─── CORS ────────────────────────────────────────────────────────────────────
# Frontend origin for CORS whitelist
WEB_ORIGIN=http://localhost:5173
